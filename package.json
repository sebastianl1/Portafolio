{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://sebastianl1.github.io/Portafolio",
  "scripts": {
    "start": "node ./node_modules/vite/bin/vite.js",
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "deploy": "node ./node_modules/gh-pages/bin/gh-pages.js -d dist",
    "lint": "node ./node_modules/eslint/bin/eslint.js src/",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write src/"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "prettier": "^3.9.5",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.3.0"
  }
}
